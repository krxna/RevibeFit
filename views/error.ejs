<div class="min-h-[60vh] flex items-center justify-center">
    <div class="max-w-lg w-full bg-white rounded-lg shadow-md p-8 text-center">
        <div class="mb-6">
            <svg class="mx-auto h-16 w-16 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
        </div>
        
        <h1 class="text-2xl font-bold text-gray-800 mb-4">Oops! Something went wrong</h1>
        
        <% if (typeof error === 'string') { %>
            <p class="text-gray-600 mb-6"><%= error %></p>
        <% } else if (error && error.message) { %>
            <p class="text-gray-600 mb-6"><%= error.message %></p>
        <% } else { %>
            <p class="text-gray-600 mb-6">An unexpected error occurred. Please try again later.</p>
        <% } %>

        <% if (process.env.NODE_ENV === 'development' && error && error.stack) { %>
            <div class="mt-6 p-4 bg-gray-100 rounded-lg">
                <p class="text-left text-xs font-mono text-gray-600 whitespace-pre-wrap"><%= error.stack %></p>
            </div>
        <% } %>

        <div class="mt-6">
            <a href="/" class="inline-block px-6 py-3 bg-[#3f8554] text-white rounded-lg hover:opacity-90 transition-opacity">
                Return to Home
            </a>
        </div>
    </div>
</div> 