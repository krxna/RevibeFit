<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .custom-green {
            --tw-text-opacity: 1;
            color: rgba(82, 145, 100, var(--tw-text-opacity));
        }
        .custom-green-bg {
            --tw-bg-opacity: 1;
            background-color: rgba(82, 145, 100, var(--tw-bg-opacity));
        }
        .custom-green-hover:hover {
            --tw-bg-opacity: 1;
            background-color: rgba(72, 135, 90, var(--tw-bg-opacity));
        }
        .custom-green-ring {
            --tw-ring-opacity: 1;
            --tw-ring-color: rgba(82, 145, 100, var(--tw-ring-opacity));
        }
        .custom-green-border {
            --tw-border-opacity: 1;
            border-color: rgba(82, 145, 100, var(--tw-border-opacity));
        }
        .custom-green-bg-light {
            --tw-bg-opacity: 0.1;
            background-color: rgba(82, 145, 100, var(--tw-bg-opacity));
        }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-10 rounded-xl shadow-lg">
        <!-- Logo -->
        <div>
            <img class="mx-auto h-16 w-auto" src="/Assets/exercise_8407005.png" alt="RevibeFit Logo">
            <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900">
                Create your account
            </h2>
            <p class="mt-2 text-center text-sm text-gray-600">
                Already have an account?
                <a href="/auth/login" class="font-medium custom-green hover:opacity-80">
                    Sign in
                </a>
            </p>
        </div>

        <!-- Error Messages -->
        <% if (messages.error && messages.error.length > 0) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative" role="alert">
                <span class="block sm:inline"><%= messages.error %></span>
            </div>
        <% } %>

        <!-- Registration Form -->
        <form class="mt-8 space-y-6" action="/auth/register" method="POST">
            <div class="rounded-md shadow-sm space-y-4">
                <!-- Name -->
                <div>
                    <label for="name" class="sr-only">Full Name</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-user text-gray-400"></i>
                        </div>
                        <input id="name" name="name" type="text" required 
                            class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                            placeholder="Full Name">
                    </div>
                </div>

                <!-- Email -->
                <div>
                    <label for="email" class="sr-only">Email address</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-gray-400"></i>
                        </div>
                        <input id="email" name="email" type="email" required 
                            class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                            placeholder="Email address">
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="sr-only">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-400"></i>
                        </div>
                        <input id="password" name="password" type="password" required 
                            class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                            placeholder="Password">
                    </div>
                </div>

                <!-- Role Selection -->
                <div class="space-y-2">
                    <label class="text-sm font-medium text-gray-700">I want to join as:</label>
                    <div class="grid grid-cols-3 gap-3">
                        <label class="relative flex flex-col bg-white border border-gray-300 rounded-lg p-4 cursor-pointer hover:border-custom-green transition-colors">
                            <input type="radio" name="role" value="client" class="sr-only" checked>
                            <span class="flex items-center justify-center text-xl mb-2">
                                <i class="fas fa-user custom-green"></i>
                            </span>
                            <span class="text-sm font-medium text-center">Client</span>
                        </label>
                        <label class="relative flex flex-col bg-white border border-gray-300 rounded-lg p-4 cursor-pointer hover:border-custom-green transition-colors">
                            <input type="radio" name="role" value="trainer" class="sr-only">
                            <span class="flex items-center justify-center text-xl mb-2">
                                <i class="fas fa-dumbbell custom-green"></i>
                            </span>
                            <span class="text-sm font-medium text-center">Trainer</span>
                        </label>
                        <label class="relative flex flex-col bg-white border border-gray-300 rounded-lg p-4 cursor-pointer hover:border-custom-green transition-colors">
                            <input type="radio" name="role" value="partner" class="sr-only">
                            <span class="flex items-center justify-center text-xl mb-2">
                                <i class="fas fa-handshake custom-green"></i>
                            </span>
                            <span class="text-sm font-medium text-center">Partner</span>
                        </label>
                    </div>
                </div>

                <!-- Role-specific fields (shown/hidden based on selection) -->
                <div id="clientFields" class="space-y-4">
                    <div>
                        <label for="fitnessGoals" class="sr-only">Fitness Goals</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-bullseye text-gray-400"></i>
                            </div>
                            <input id="fitnessGoals" name="fitnessGoals" type="text"
                                class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                                placeholder="Your fitness goals">
                        </div>
                    </div>
                </div>

                <div id="trainerFields" class="space-y-4 hidden">
                    <div>
                        <label for="specialization" class="sr-only">Specialization</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-certificate text-gray-400"></i>
                            </div>
                            <input id="specialization" name="specialization" type="text"
                                class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                                placeholder="Your specialization">
                        </div>
                    </div>
                    <div>
                        <label for="certification" class="sr-only">Certification</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-award text-gray-400"></i>
                            </div>
                            <input id="certification" name="certification" type="text"
                                class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                                placeholder="Your certification">
                        </div>
                    </div>
                </div>

                <div id="partnerFields" class="space-y-4 hidden">
                    <div>
                        <label for="labName" class="sr-only">Lab/Business Name</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-building text-gray-400"></i>
                            </div>
                            <input id="labName" name="labName" type="text"
                                class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                                placeholder="Lab/Business Name">
                        </div>
                    </div>
                    <div>
                        <label for="services" class="sr-only">Services Offered</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-list text-gray-400"></i>
                            </div>
                            <input id="services" name="services" type="text"
                                class="appearance-none rounded-lg relative block w-full pl-10 px-3 py-3 border border-gray-300 placeholder-gray-500 text-gray-900 focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring focus:z-10 sm:text-sm" 
                                placeholder="Services Offered">
                        </div>
                    </div>
                </div>
            </div>

            <div>
                <button type="submit" 
                    class="group relative w-full flex justify-center py-3 px-4 border border-transparent text-sm font-medium rounded-lg text-white custom-green-bg custom-green-hover focus:outline-none focus:ring-2 focus:ring-offset-2 custom-green-ring transition duration-150 ease-in-out">
                    <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                        <i class="fas fa-user-plus text-white group-hover:opacity-80"></i>
                    </span>
                    Create Account
                </button>
            </div>
        </form>

        <!-- Social Registration -->
        <div class="mt-6">
            <div class="relative">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-gray-300"></div>
                </div>
                <div class="relative flex justify-center text-sm">
                    <span class="px-2 bg-white text-gray-500">Or register with</span>
                </div>
            </div>

            <div class="mt-6 grid grid-cols-2 gap-3">
                <div>
                    <a href="#" class="w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-lg shadow-sm bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                        <i class="fab fa-google text-red-500"></i>
                        <span class="ml-2">Google</span>
                    </a>
                </div>
                <div>
                    <a href="#" class="w-full inline-flex justify-center py-2 px-4 border border-gray-300 rounded-lg shadow-sm bg-white text-sm font-medium text-gray-500 hover:bg-gray-50">
                        <i class="fab fa-facebook text-blue-600"></i>
                        <span class="ml-2">Facebook</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript for handling role selection -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const roleInputs = document.querySelectorAll('input[name="role"]');
            const clientFields = document.getElementById('clientFields');
            const trainerFields = document.getElementById('trainerFields');
            const partnerFields = document.getElementById('partnerFields');

            function showFields(role) {
                clientFields.classList.add('hidden');
                trainerFields.classList.add('hidden');
                partnerFields.classList.add('hidden');

                switch(role) {
                    case 'client':
                        clientFields.classList.remove('hidden');
                        break;
                    case 'trainer':
                        trainerFields.classList.remove('hidden');
                        break;
                    case 'partner':
                        partnerFields.classList.remove('hidden');
                        break;
                }
            }

            roleInputs.forEach(input => {
                input.addEventListener('change', (e) => {
                    showFields(e.target.value);
                    
                    // Update selected styles
                    document.querySelectorAll('input[name="role"]').forEach(radio => {
                        const label = radio.closest('label');
                        if (radio.checked) {
                            label.classList.add('custom-green-border', 'custom-green-bg-light');
                        } else {
                            label.classList.remove('custom-green-border', 'custom-green-bg-light');
                        }
                    });
                });
            });

            // Initialize with default selection
            showFields('client');
            document.querySelector('input[value="client"]').closest('label').classList.add('custom-green-border', 'custom-green-bg-light');
        });
    </script>
</body>
</html> 